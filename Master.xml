<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Master Suite">

  <test name="Sanity Suite">
    <groups>
      <run>
        <include name="sanity"/>
      </run>
    </groups>
    <classes>
      <class name="b_e2e_sanity_tests.Sanity_OrderFlow_Test"/>
    </classes>
  </test>

  <test name="E2E Suite">
    <groups>
      <run>
        <include name="e2e"/>
      </run>
    </groups>
    <classes>
      <class name="b_e2e_sanity_tests.E2E_OrderFlow_Test"/>
    </classes>
  </test>

</suite>